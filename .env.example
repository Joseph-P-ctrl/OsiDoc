# Credenciales
OSI_USERNAME=tu_usuario
OSI_PASSWORD=tu_contrasena

# URLs
OSI_LOGIN_URL=https://osivirtual.osinergmin.gob.pe/autenticacion/acceso-sistema
OSI_BASE_URL=https://osivirtual.osinergmin.gob.pe

# IDs de inputs de login
OSI_USERNAME_ID=documentoIdentidad
OSI_PASSWORD_ID=contrasena

# Selectores CSS
OSI_LOGIN_FORM_SELECTOR=form
OSI_LOGIN_SUBMIT_SELECTOR=button[type='submit']

# Keyword para validar login (si sigue en esta URL, asume no autenticado)
OSI_SUCCESS_URL_KEYWORD=autenticacion/acceso-sistema

# Opciones runtime
OSI_HEADLESS=true
OSI_TIMEOUT=30
OSI_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
